# MeerGate Configuration

# Server
API_PORT=
API_HOST=

# Concurrency
MAX_CONCURRENCY=

# Timeouts (ms)
DEFAULT_STEP_TIMEOUT_MS=
DEFAULT_WS_TIMEOUT_MS=

# Auth
# JWT_SECRET: use a long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=
# Admin is seeded on first run only. DEFAULT_ADMIN_PASSWORD is REQUIRED —
# if empty, no admin is created (no insecure default).
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=

#Database
DATABASE_URL=

# Logging
LOG_LEVEL=

# AI / LLM Configuration (for Prompt-to-YAML generation)
# AI_PROVIDER: "anthropic" | "openai" | "cursor-cli"
AI_PROVIDER=

# Anthropic Claude API key (used when AI_PROVIDER=anthropic)
AI_ANTHROPIC_API_KEY=


# Model name (e.g. claude-opus-4-8, gpt-4o)
AI_MODEL=

# OpenAI / Cursor CLI API key
AI_API_KEY=

# Only needed when AI_PROVIDER=openai
AI_API_URL=
